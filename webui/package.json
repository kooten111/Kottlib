{
  "name": "kottlib-webui",
  "version": "1.0.0",
  "description": "Modern Web UI for Kottlib",
  "type": "module",
  "scripts": {
    "dev": "bun run vite dev",
    "build": "bun run vite build",
    "preview": "bun run vite preview",
    "start": "bun run vite build && PORT=5173 HOST=0.0.0.0 bun build/index.js",
    "start:no-build": "PORT=5173 HOST=0.0.0.0 bun build/index.js",
    "check": "bun run svelte-kit sync && bun run svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "bun run svelte-kit sync && bun run svelte-check --tsconfig ./jsconfig.json --watch"
  },
  "keywords": [
    "yacreader",
    "comics",
    "webui"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/kit": "^2.48.4",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/types": "^8.59.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "svelte": "^5.43.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.1",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "lucide-svelte": "^0.553.0"
  }
}
