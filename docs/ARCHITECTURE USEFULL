/comic/{libraryId}/{comicId}
  GET /library/{id}/comic/{id}/fullinfo - Load comic details

/comic/{libraryId}/{comicId}/read
  GET /library/{id}/comic/{id}/fullinfo - Load comic
  GET /library/{id}/comic/{id}/page/{pageNum}/remote - Load page images
  POST /library/{id}/comic/{id}/update - Update progress on page change

