{
  "scanner_name": "AniList",
  "description": "Series-level scanner for manga and light novel metadata from AniList GraphQL API",
  "scan_level": "SERIES",
  "scanning_mode": "by_series",
  "api_endpoint": "https://graphql.anilist.co",
  "rate_limit": {
    "requests_per_minute": 90,
    "delay_between_requests": 0.7
  },
  "matching": {
    "confidence_threshold": 0.6,
    "fuzzy_match_threshold": 0.7,
    "use_romaji_titles": true,
    "use_english_titles": true,
    "use_native_titles": false
  },
  "api_options": {
    "timeout": 10,
    "retry_attempts": 3,
    "retry_delay": 2
  },
  "metadata_mapping": {
    "include_staff": true,
    "include_genres": true,
    "include_tags": true,
    "include_relations": true,
    "max_characters": 10
  }
}
